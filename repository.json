{
  "plugins": [
    {
      "manifest": {
        "plugin_id": "wisp",
        "version": "0.1.7",
        "silo_api_version": "v1",
        "supported_platforms": [
          {
            "os": "linux",
            "arch": "amd64"
          },
          {
            "os": "linux",
            "arch": "arm64"
          }
        ],
        "capabilities": [
          {
            "type": "request_router.v1",
            "id": "wisp-requests",
            "display_name": "Wisp Requests",
            "description": "Delegates movie and series fulfillment to a Wisp server's HTTP API.",
            "config_schema": [
              {
                "key": "connection",
                "json_schema": "{\"type\":\"object\",\"properties\":{\"wisp_url\":{\"type\":\"string\",\"title\":\"Wisp URL\"},\"wisp_token\":{\"type\":\"string\",\"title\":\"Wisp Token\"}},\"required\":[\"wisp_url\"]}",
                "admin_form": {
                  "fields": [
                    {
                      "key": "wisp_url",
                      "label": "Wisp URL",
                      "control": 1,
                      "required": true,
                      "description": "Base URL of the Wisp server. Example: http://wisp:8080",
                      "placeholder": "http://wisp:8080"
                    },
                    {
                      "key": "wisp_token",
                      "label": "Wisp Token",
                      "control": 3,
                      "secret": true,
                      "description": "Optional token. When set it is sent to Wisp as an Authorization: Bearer header. Leave empty if Wisp requires no authentication.",
                      "placeholder": "optional-bearer-token"
                    }
                  ]
                }
              }
            ]
          }
        ],
        "presentation": {
          "display_name": "Wisp Request Router",
          "summary": "Thin Silo request router that delegates all movie and series fulfillment to a Wisp server.",
          "description_markdown": "A purpose-built request_router.v1 shim. Every request Silo routes here is handed to a Wisp server over its stable HTTP API (POST /api/add); Wisp owns all resolution, quality pinning, and status. The plugin holds no business logic and never blocks: it makes a single fast HTTP call and returns.",
          "setup_markdown": "Install the plugin, then add a connection under Admin -> Plugins -> Wisp and set the Wisp URL (e.g. http://wisp:8080). Use Test Connection to confirm reachability.",
          "homepage_url": "https://github.com/dreulavelle/silo-plugin-wisp",
          "source_url": "https://github.com/dreulavelle/silo-plugin-wisp",
          "support_url": "https://github.com/dreulavelle/silo-plugin-wisp/issues",
          "changelog_url": "https://github.com/dreulavelle/silo-plugin-wisp/releases",
          "publisher_name": "dreulavelle",
          "publisher_url": "https://github.com/dreulavelle",
          "license_spdx": "MIT"
        }
      },
      "repo_url": "https://github.com/dreulavelle/silo-plugin-wisp",
      "checksums_url": "https://github.com/dreulavelle/silo-plugin-wisp/releases/download/v0.1.7/checksums.txt",
      "binaries": {
        "linux/amd64": {
          "url": "https://github.com/dreulavelle/silo-plugin-wisp/releases/download/v0.1.7/silo-plugin-wisp-linux-amd64",
          "checksum": "12c087d6d91ef24ee79951f489e088cfb7076b843e711791bed2a9cca0c5b375"
        },
        "linux/arm64": {
          "url": "https://github.com/dreulavelle/silo-plugin-wisp/releases/download/v0.1.7/silo-plugin-wisp-linux-arm64",
          "checksum": "410acc2055c0e4601e4b21ea4f1fd4c6f66e0542c737b377bb747b2322566587"
        }
      }
    }
  ]
}
